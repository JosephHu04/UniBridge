# UniBridge — Environment Configuration
# Copy this file to .env and fill in your values

# Database (PostgreSQL)
# Defaults work for local development with a trusted socket connection
DB_USERNAME=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_DEV_DATABASE=RateMyProfs_development
DB_TEST_DATABASE=RateMyProfs_test

# Rails
RAILS_ENV=development
SECRET_KEY_BASE=development_secret_do_not_use_in_production

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password
