#!/usr/bin/env ruby
require 'fileutils'
include FileUtils

APP_ROOT = File.expand_path('..', __dir__)

def system!(*args)
  system(*args) || abort("\n== Command #{args} failed ==")
end

chdir APP_ROOT do
  puts '=============================================='
  puts '  UniBridge — Setup'
  puts '=============================================='

  puts "\n== Installing dependencies =="
  system! 'gem install bundler --conservative'
  system('bundle check') || system!('bundle install')
  system('npm install --legacy-peer-deps') unless File.exist?('node_modules/.package-lock.json')

  puts "\n== Preparing database =="
  if ENV['RESET_DB'] == 'true'
    puts 'RESET_DB=true detected — running destructive db:setup'
    system! 'bin/rails db:environment:set RAILS_ENV=development 2>/dev/null'
    system! 'bin/rails db:setup'
  else
    puts 'Non-destructive: db:create + db:migrate + db:seed'
    system! 'bin/rails db:create 2>/dev/null'
    system! 'bin/rails db:migrate'
    system! 'bin/rails db:seed'
  end

  puts "\n== Generating demo data =="
  system! 'bin/rails seed:demo_data'

  puts "\n== Importing QS rankings =="
  system! 'bin/rails import:qs_2025'

  puts "\n== Compiling frontend =="
  system! 'npx webpack --mode=development'

  puts "\n== Removing old logs and tempfiles =="
  system! 'bin/rails log:clear tmp:clear'

  puts "\n=============================================="
  puts '  Setup complete!'
  puts '  Start the server: bin/rails server'
  puts '  Admin: http://localhost:3000/admin'
  puts '  (admin@example.com / password)'
  puts '=============================================="
end
